# Copy this file to .env and fill in the values

# JWT secret key — use a long random string in production
SECRET_KEY=your-super-secret-key-change-me

# SQLite (default, no change needed for local dev)
# DATABASE_URL=sqlite:///./splitwise.db

# On Render, this is set automatically via render.yaml to point to the mounted disk
# DATABASE_URL=sqlite:////opt/render/project/src/splitwise.db
